# ============================================================
#  Eco Yacht Surveyors — Apache rewrite & config
#  Clean URLs: /about/ serves about.html (no .html in links)
# ============================================================

RewriteEngine On

# --- Contact form API -> PHP handler ---
RewriteRule ^api/contact$ api/contact.php [L]

# --- Force https + canonical domain (uncomment when live) ---
# RewriteCond %{HTTPS} off [OR]
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.ecoyachtsurveyors.com%{REQUEST_URI} [L,R=301]

# --- Clean URLs ---
# Trailing slash, e.g. /about/  ->  about.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-z0-9-]+)/$ $1.html [L]

# No trailing slash, e.g. /about  ->  /about/ (then rule above catches it)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-z0-9-]+)$ /$1/ [R=301,L]

# Service subpages: /services/pre-purchase-survey/ -> services/pre-purchase-survey.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^services/([a-z0-9-]+)/$ services/$1.html [L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^services/([a-z0-9-]+)$ /services/$1/ [R=301,L]

# --- Drop the .html extension if typed directly (301 to clean URL) ---
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([a-z0-9-]+)\.html [NC]
RewriteRule ^ /%1/ [R=301,L]

# --- Default document ---
DirectoryIndex index.html

# --- Security: protect sensitive files ---
<FilesMatch "^(\.env|\.gitignore|package\.json|package-lock\.json|server\.js|email-template\.html)$">
  Require all denied
</FilesMatch>

# --- Security: disable directory listing ---
Options -Indexes

# --- Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# --- Browser caching ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
</IfModule>

# --- Custom 404 ---
ErrorDocument 404 /404.html
